# ============================================
# CardioSense ML API Environment Variables
# ============================================
# Copy this to .env and fill in your values

# MongoDB Atlas Connection
# IMPORTANT: Replace <your_username> with your actual Atlas username
# The <db_password> placeholder is automatically replaced by CARDIOSENSE_MONGODB_PASSWORD
CARDIOSENSE_MONGODB_URI=mongodb+srv://<your_username>:<db_password>@cluster0.udvrzpa.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Your Atlas database user password
CARDIOSENSE_MONGODB_PASSWORD=n3FkbiBV85h1E20S

# Database name
CARDIOSENSE_MONGODB_DATABASE=cardiosense

# CORS - Frontend URLs
CARDIOSENSE_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Security
CARDIOSENSE_HASH_SALT=change-me-in-production

# Logging
CARDIOSENSE_LOG_LEVEL=INFO
CARDIOSENSE_LOG_PAYLOADS=false
CARDIOSENSE_REQUEST_BODY_MAX_CHARS=2048

# Threshold Optimization
CARDIOSENSE_ENABLE_THRESHOLD_OPTIMIZATION=true
CARDIOSENSE_THRESHOLD_OPTIMIZATION_OBJECTIVE=balanced_accuracy

# Drift Detection
CARDIOSENSE_DRIFT_FEATURE_PSI_THRESHOLD=0.20
CARDIOSENSE_DRIFT_PREDICTION_SHIFT_THRESHOLD=0.15
CARDIOSENSE_DRIFT_MIN_SAMPLE_SIZE=25

# Model Loading
CARDIOSENSE_BOOTSTRAP_LOCAL_MODEL=true