# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers → copy the connection string
# Replace <username>, <password>, and <dbname> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cardiosense?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret

# ── Python ML API (optional) ──────────────────────────────────────────────────
# If you deploy the Python FastAPI (ml/ folder) to Render, paste its URL here.
# Leave blank to use the built-in fallback risk formula instead.
# ML_API_URL=https://cardiosense-ml.onrender.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (Vercel). For local dev localhost:5173 is always allowed.
# FRONTEND_URL=https://your-app.vercel.app
